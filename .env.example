# ---- Credenciales de Google (Gemini API / AI Studio) ----
# Consíguela en: https://aistudio.google.com/apikey
# El SDK google-genai la lee automáticamente de GEMINI_API_KEY.
GEMINI_API_KEY=pega_aqui_tu_api_key

# ---- Qdrant local (Docker) ----
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=ktm_rag

# ---- RAG config ----
EMBED_MODEL=gemini-embedding-2
GEN_MODEL=gemini-3.5-flash    # flash estable vigente (o gemini-flash-latest = auto-actualiza)
EMBED_DIM=3072          # 3072 = calidad máxima. 768/1536 = más barato de almacenar
CORPUS_DIR=./corpus     # <-- suelta aquí tus PDFs / imágenes / txt
STORAGE_DIR=./storage   # páginas renderizadas + manifiesto (no tocar)
TOP_K=5
PAGE_DPI=150
